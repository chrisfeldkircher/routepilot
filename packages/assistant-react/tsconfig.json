{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@routepilot/engine": ["../engine/src/index.ts"],
      "@routepilot/react": ["../react/src/index.ts"],
      "@routepilot/assistant": ["../assistant/src/index.ts"],
      "@routepilot/assistant/*": ["../assistant/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
