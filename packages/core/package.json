{
  "name": "@routepilot/core",
  "version": "0.1.0",
  "description": "Guided tour engine for React.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./tour.css": "./src/tour.css",
    "./tour-utilities.css": "./src/tour-utilities.css"
  },
  "scripts": {
    "build:css": "tailwindcss -i src/tailwind-input.css -o src/tour-utilities.css --minify -c tailwind.config.js",
